BOT_TOKEN=your_telegram_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here
ADMIN_IDS=123456789
DATABASE_PATH=bot.db
IMAGES_DIR=data/images
GEMINI_MODEL=gemini-1.5-flash
MAX_EXAM_QUESTIONS=30
THROTTLE_RATE=0.5

# Mini App URL — set to your public HTTPS URL (Railway auto-sets this, for local use ngrok)
WEBAPP_URL=https://your-app.railway.app

# Set to true for local browser testing (skips Telegram auth)
DEBUG=false
